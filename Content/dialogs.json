{
  "$schema": "roguelike-dialogs-v1",
  "version": 1,
  "dialogs": [
    {
      "id": "merchant_intro",
      "start_node": "start",
      "start_nodes": [
        "start",
        "start_supplies",
        "start_warning"
      ],
      "nodes": [
        {
          "id": "start",
          "text": "I trade in things that keep you alive: medicine, steel, and one spare shield when luck goes bad.",
          "options": [
            {
              "text": "Show me what you have.",
              "action": "shop"
            },
            {
              "text": "What should I prioritize?",
              "next": "advice"
            },
            {
              "text": "I will be moving on.",
              "action": "close"
            }
          ]
        },
        {
          "id": "start_supplies",
          "text": "Fresh bandages, questionable scrolls, and boots that have seen fewer corpses than most. Pick what solves your next problem.",
          "options": [
            {
              "text": "Show me what you have.",
              "action": "shop"
            },
            {
              "text": "What should I prioritize?",
              "next": "advice"
            },
            {
              "text": "I will be moving on.",
              "action": "close"
            }
          ]
        },
        {
          "id": "start_warning",
          "text": "Do not wait until you are bleeding to shop. The dungeon charges interest, and it collects in teeth.",
          "options": [
            {
              "text": "Show me what you have.",
              "action": "shop"
            },
            {
              "text": "What should I prioritize?",
              "next": "advice"
            },
            {
              "text": "I will be moving on.",
              "action": "close"
            }
          ]
        },
        {
          "id": "advice",
          "text": "Buy for the floor you are on. Mobility and recovery solve more runs than greedy upgrades you cannot afford to carry.",
          "options": [
            {
              "text": "Back to your stock.",
              "action": "shop"
            },
            {
              "text": "Understood.",
              "action": "close"
            }
          ]
        }
      ]
    },
    {
      "id": "chronicler_intro",
      "start_node": "start",
      "start_nodes": [
        "start",
        "start_memory",
        "start_warning"
      ],
      "nodes": [
        {
          "id": "start",
          "text": "Every floor teaches the same lesson: carry fewer things, but know exactly why each one is in your pack.",
          "options": [
            {
              "text": "Explain.",
              "next": "pack_logic"
            },
            {
              "text": "I have heard enough.",
              "action": "close"
            }
          ]
        },
        {
          "id": "start_memory",
          "text": "I have recorded four deaths on this floor alone. Three were greed, one was a door opened too quickly.",
          "options": [
            {
              "text": "Explain.",
              "next": "pack_logic"
            },
            {
              "text": "I have heard enough.",
              "action": "close"
            }
          ]
        },
        {
          "id": "start_warning",
          "text": "The survivors all did one thing well: they left themselves an answer for when the plan failed.",
          "options": [
            {
              "text": "Explain.",
              "next": "pack_logic"
            },
            {
              "text": "I have heard enough.",
              "action": "close"
            }
          ]
        },
        {
          "id": "pack_logic",
          "text": "A clean bag means faster decisions. Sell dead weight, keep one emergency heal, and compare gear by the stat it changes for your build.",
          "options": [
            {
              "text": "That helps.",
              "action": "close"
            }
          ]
        }
      ]
    }
  ]
}

<Project Sdk="Godot.NET.Sdk/4.5.2">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>12</LangVersion>
    <RootNamespace>Godotussy</RootNamespace>
    <AssemblyName>godotussy</AssemblyName>
  </PropertyGroup>

  <PropertyGroup Condition="'$(UseGodotStubs)' == 'true'">
    <OutputPath>bin\godotstubs\$(Configuration)\$(TargetFramework)\</OutputPath>
    <DisableImplicitGodotGeneratorReferences>true</DisableImplicitGodotGeneratorReferences>
    <DisableImplicitGodotSharpReferences>true</DisableImplicitGodotSharpReferences>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Addons\roguelike_tools\RoguelikeToolsPlugin.cs" />
    <Compile Remove="Tests\**\*.cs" />
    <Compile Remove="obj\**\*.cs" />
    <Compile Remove=".godot\**\*.cs" />
    <Compile Remove="Compat\Godot\GodotStubs.cs" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseGodotStubs)' == 'true'">
    <Compile Include="Addons\roguelike_tools\RoguelikeToolsPlugin.cs" />
    <Compile Include="Compat\Godot\GodotStubs.cs" />
  </ItemGroup>

  <ItemGroup Condition="'$(RenderingValidation)' == 'true'">
    <Compile Remove="Core\Persistence\**\*.cs" />
    <Compile Include="Core\Persistence\MetaProgressionData.cs" />
  </ItemGroup>

  <PropertyGroup Condition="'$(RenderingValidation)' == 'true'">
    <DefineConstants>$(DefineConstants);RENDERING_VALIDATION</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <None Include="project.godot" />
    <None Include="Scenes\**\*" />
    <None Include="Assets\**\*" />
    <None Include="Content\**\*" />
    <None Include="Addons\**\*" />
  </ItemGroup>
</Project>
